# Copy to .env and set values. Never commit .env.
PORT=3000
JWT_SECRET=your-secret-key-from-secure-source
JWT_EXPIRY=1d
MONGODB_URI=mongodb://user:password@localhost:27017/mydb
API_KEY=
# Comma-separated hosts allowed for lib/fetch.js (SSRF protection). Default: localhost,127.0.0.1
# ALLOWED_FETCH_HOSTS=localhost,127.0.0.1,api.example.com
# Optional: JSON object of username -> password for /auth/login
# AUTH_USERS={"admin":"securepassword","user":"userpassword"}
